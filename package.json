    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.56.1",
