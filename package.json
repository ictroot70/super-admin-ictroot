{
  "name": "super-admin-ictroot",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build",
    "build:production": "next build",
    "ci:check": "pnpm lint:ci && pnpm lint:styles:ci && pnpm typecheck && pnpm format:check && pnpm build",
    "codegen": "graphql-codegen --config codegen.ts",
    "codegen:watch": "graphql-codegen --config codegen.ts --watch",
    "dev": "next dev",
    "format": "prettier --write \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,scss,graphql}\" package.json",
    "format:check": "prettier --check \"**/*.{js,mjs,cjs,jsx,ts,tsx,css,scss,graphql}\" package.json",
    "lint": "eslint .",
    "lint:ci": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "lint:styles": "stylelint \"**/*.{css,scss}\"",
    "lint:styles:ci": "stylelint \"**/*.{css,scss}\" --max-warnings 0",
    "lint:styles:fix": "stylelint \"**/*.{css,scss}\" --fix",
    "prepare": "husky",
    "start": "next start",
    "type-check": "pnpm run typecheck",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm lint && pnpm lint:styles && pnpm typecheck && pnpm format:check"
  },
  "dependencies": {
    "@apollo/client": "^4.1.7",
    "@fontsource-variable/inter": "^5.2.6",
    "@fontsource-variable/roboto": "^5.2.6",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@hookform/resolvers": "^5.1.1",
    "@ictroot/ui-kit": "2.0.0-beta.5",
    "clsx": "^2.1.1",
    "graphql": "^16.13.2",
    "graphql-ws": "^6.0.8",
    "i18next": "^25.3.2",
    "i18next-browser-languagedetector": "^8.2.0",
    "next": "16.2.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.56.1",
    "react-toastify": "^11.0.5",
    "zod": "^3.25.67",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^7.0.0",
    "@graphql-codegen/client-preset": "^6.0.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-node": "^0.3.10",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-perfectionist": "^5.9.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "3.5.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sass": "^1.87.0",
    "stylelint": "^17.0.0",
    "stylelint-config-clean-order": "^8.0.1",
    "stylelint-config-standard-scss": "^17.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "packageManager": "pnpm@10.11.1",
  "engines": {
    "node": ">=20"
  }
}
